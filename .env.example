# AI Studio reads this file to know which secrets to inject.
# Optional variables are left blank — AI Studio will not demand them.
# For a full reference of all variables with descriptions,
# see .env.full.example in this repository.

GEMINI_API_KEY="MY_GEMINI_API_KEY"
MODEL_ID=
GROQ_API_KEY=
GROQ_MODEL_ID=
APP_URL=

# ==========================================
# 🏠 PLATFORM OWNER CONFIGURATION
# ==========================================
# PLATFORM_TENANT_ID: Your own tenant ID — the account that owns the EnrollAI homepage bot.
# All leads, conversations, and appointments captured by the homepage chatbot (platform mode)
# will be stored under this tenant ID, regardless of how many clients sign up.
#
# ⚠️  IMPORTANT: Set this BEFORE opening your app to the public.
#     The correct sequence is:
#       1. Deploy the app to your server
#       2. Register YOUR OWN account (first login creates your tenant ID)
#       3. Find your tenant ID using the steps below
#       4. Paste it into this file
#       5. Restart the server (see restart instructions below)
#       6. THEN share your URL with clients and the public
#
# HOW TO FIND YOUR TENANT ID:
#   1. Log into your EnrollAI dashboard in the browser
#   2. Press F12 to open DevTools (or right-click → Inspect)
#   3. Click the "Application" tab at the top of DevTools
#   4. In the left sidebar, click "Local Storage" then click your site URL
#   5. Find the row called: enrollai_tenant_id
#   6. Copy the value in the right column (looks like: tenant-1234567890)
#   7. Paste it below between the quotes
#
# HOW TO RESTART THE SERVER AFTER SETTING THIS VALUE:
#
#   — If you are using PM2 (most common on DigitalOcean / Namecheap VPS):
#       ssh user@your-server-ip
#       nano /path/to/your/app/.env        # edit this file, save with Ctrl+X then Y
#       pm2 restart enrollai               # replace "enrollai" with your PM2 process name
#       pm2 logs enrollai                  # confirm the server restarted without errors
#
#   — If you are using systemd:
#       ssh user@your-server-ip
#       nano /path/to/your/app/.env
#       sudo systemctl restart enrollai
#       sudo journalctl -u enrollai -f     # confirm restart
#
#   — If you are running Node directly (not recommended for production):
#       ssh user@your-server-ip
#       nano /path/to/your/app/.env
#       # kill the old process, then start it again with your normal start command
#
#   The restart takes 3–5 seconds. Your app goes down briefly and comes back up
#   with the new value loaded. Your database (SQLite) is untouched — no data is lost.
#
# If this is left blank, homepage leads will fall back to the first registered tenant
# in the database — which is UNSAFE once paying clients exist.
PLATFORM_TENANT_ID=""

# JWT_SECRET: Required. Secret key for signing session tokens.
# Generate a secure value: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_A_64_CHARACTER_RANDOM_HEX_STRING"

SUPABASE_URL=
VITE_SUPABASE_URL=
SUPABASE_ANON_KEY=
VITE_SUPABASE_ANON_KEY=

# Supabase Service Role Key — SERVER SIDE ONLY. Never put in VITE_ prefix. Never expose to browser.
# Found at: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=
SUPPORT_GMAIL_USER=
SUPPORT_GMAIL_APP_PASSWORD=
SUPPORT_RECEIVER_EMAIL=
LEAD_NOTIFICATION_EMAIL=
CAMPAY_USERNAME=
CAMPAY_PASSWORD=
CAMPAY_ENV=
CAMPAY_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
VITE_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=
PAYPAL_WEBHOOK_ID=
USD_TO_FCFA_RATE=
PP_PLAN_STARTER_MO=
PP_PLAN_STARTER_YR=
PP_PLAN_GROWTH_MO=
PP_PLAN_GROWTH_YR=
PP_PLAN_PRO_MO=
PP_PLAN_PRO_YR=
PP_PLAN_AGENCY_MO=
PP_PLAN_AGENCY_YR=
